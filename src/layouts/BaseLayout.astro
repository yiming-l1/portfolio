---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { Image } from "astro:assets";
import logo from "../assets/images/logo1.svg";
import logoHover from "../assets/images/logo2.svg";

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link
      rel="preload"
      href="/fonts/danielbk.ttf"
      as="font"
      type="font/ttf"
      crossorigin="anonymous"
    />
    <ClientRouter />
  </head>

  <body>
    <div class="layout-container">
      <aside class="sidebar">
        <a href="/" class="logo-link">
          <Image src={logo} alt="Yiming." class="logo-default" />
          <Image src={logoHover} alt="Yiming." class="logo-hover" />
        </a>

        <nav class="nav-links">
          <a href="/about" class={currentPath === "/about" ? "active" : ""}
            >about</a
          >
          <a
            href="/projects"
            class={currentPath === "/projects" ? "active" : ""}>works</a
          >
          <a href="/blog" class={currentPath === "/blog" ? "active" : ""}
            >blog</a
          >
          <a href="/contact" class={currentPath === "/contact" ? "active" : ""}
            >contact</a
          >
        </nav>
      </aside>

      <main class="main-content">
        <slot />

        <footer>Copyright &copy; 2026 Yiming Li. All Rights Reserved.</footer>
      </main>
    </div>
  </body>
</html>
