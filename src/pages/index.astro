---
import BaseLayout from "../layouts/BaseLayout.astro";
import person from "../assets/images/person.png";
import chatbox from "../assets/images/chatbox.png";
---

<BaseLayout title="Yiming Li">
  <style>
    .chatbox-wrapper:hover {
      transform: scale(1.08) rotate(4deg);
    }
  </style>

  <div
    style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; min-height: 60vh; margin-top: 40px;"
  >
    <div
      id="main-art-container"
      style="position: relative; width: 100%; max-width: 450px; height: 350px; display: flex; justify-content: center; align-items: flex-end;"
    >
      <!-- Chatbox with overlay text -->
      <div
        class="chatbox-wrapper"
        style="position: absolute; top: -40px; left: -40px; width: 220px; cursor: pointer; transition: transform 0.3s ease; z-index: 10;"
      >
        <img
          src={chatbox.src}
          alt="Chatbox"
          style="left: 50%; width: 160%; display: block; pointer-events: none;"
        />
        <p
          id="chatbox-text"
          style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 75%; text-align: center; margin: 0; font-family: var(--main-font); font-size: 20px; pointer-events: none; line-height: 1.2;"
        >
        </p>
      </div>

      <!-- Person Line Art -->
      <img
        src={person.src}
        alt="Person"
        style="max-height: 100%; max-width: 100%; pointer-events: none; position: relative; z-index: 5;"
      />
    </div>
  </div>

  <!-- Form Popup -->
  <div
    id="form-overlay"
    style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.4); z-index: 99; backdrop-filter: blur(2px);"
  >
  </div>

  <div
    id="form-popup"
    style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background-color: var(--bg-color, #fff); border: 2px solid var(--text-color, #000); border-radius: 16px; padding: 40px; z-index: 100; flex-direction: column; align-items: center; box-shadow: 0 10px 30px rgba(0,0,0,0.15); width: 90%; max-width: 400px;"
  >
    <button
      id="close-form"
      style="position: absolute; top: 15px; right: 20px; background: none; border: none; font-size: 24px; cursor: pointer; color: var(--text-color, #000); transition: transform 0.2s ease;"
      onmouseover="this.style.transform='scale(1.2)'"
      onmouseout="this.style.transform='scale(1)'"
    >
      &times;
    </button>
    <form
      name="chatbox-contact"
      method="POST"
      data-netlify="true"
      style="width: 100%; display: flex; flex-direction: column; gap: 20px;"
    >
      <!-- Hidden input for Netlify forms -->
      <input type="hidden" name="form-name" value="chatbox-contact" />

      <h3
        style="margin: 0; font-family: var(--primary-font, inherit); text-align: center; font-size: 20px;"
      >
        do you want to share something with me?
      </h3>
      <textarea
        name="message"
        required
        rows="4"
        style="width: 100%; padding: 10px; border: 1px solid var(--text-color, #000); border-radius: 8px; font-family: inherit; font-size: 16px; resize: vertical; background: transparent; color: var(--text-color);"
      ></textarea>

      <p
        style="margin: 0; font-family: var(--primary-font, inherit); text-align: center; font-size: 20px;"
      >
        leave your email address so I can get back to you!
      </p>
      <input
        type="email"
        name="email"
        required
        style="width: 100%; padding: 10px; border: 1px solid var(--text-color, #000); border-radius: 8px; font-family: inherit; font-size: 16px; background: transparent; color: var(--text-color);"
      />

      <button
        type="submit"
        style="padding: 10px 20px; background-color: var(--accent-color, #4CAF50); color: var(--bg-color, #fff); border: none; border-radius: 25px; font-family: inherit; font-size: 18px; cursor: pointer; align-self: center; transition: opacity 0.2s ease;"
        onmouseover="this.style.opacity='0.8'"
        onmouseout="this.style.opacity='1'"
      >
        Send
      </button>
    </form>
  </div>

  <script>
    const messages = [
      "hello there!",
      "hey:)",
      "what's your thoughts today?",
      "just another day working on...",
      "i'm thinking about ...",
    ];

    const textElement = document.getElementById("chatbox-text");
    if (textElement) {
      const playAnimation = () => {
        const randomIndex = Math.floor(Math.random() * messages.length);
        const textToType = messages[randomIndex];

        // Start with empty text
        textElement.textContent = "";
        let i = 0;

        const typeWriter = () => {
          if (i < textToType.length) {
            textElement.textContent += textToType.charAt(i);
            i++;
            // Randomize typing speed for realism (40ms - 90ms)
            const speed = Math.floor(Math.random() * 50) + 40;
            setTimeout(typeWriter, speed);
          } else {
            // Wait 3 seconds, then restart the animation with a new phrase
            setTimeout(playAnimation, 3000);
          }
        };

        // Add a slight delay before typing starts
        setTimeout(typeWriter, 400);
      };

      playAnimation();
    }

    // Popup Logic
    const chatboxWrapper = document.querySelector(".chatbox-wrapper");
    const formPopup = document.getElementById("form-popup");
    const formOverlay = document.getElementById("form-overlay");
    const closeFormBtn = document.getElementById("close-form");

    if (chatboxWrapper && formPopup && formOverlay && closeFormBtn) {
      chatboxWrapper.addEventListener("click", () => {
        formPopup.style.display = "flex";
        formOverlay.style.display = "block";
      });

      const closeForm = () => {
        formPopup.style.display = "none";
        formOverlay.style.display = "none";
      };

      closeFormBtn.addEventListener("click", closeForm);
      formOverlay.addEventListener("click", closeForm);
    }
  </script>
</BaseLayout>
