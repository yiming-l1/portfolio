---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Yiming Li">
  
  <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; min-height: 60vh;">
    
    <!-- Placeholder for the main line art with interactive element -->
    <div class="placeholder-art" style="width: 100%; max-width: 500px; height: 300px; position: relative;">
      <p>Main Line Art goes here</p>
      
      <!-- Interactive element placeholder (e.g. contact form hidden in art) -->
      <button style="position: absolute; bottom: 20px; right: 20px; background: none; border: 2px solid var(--accent-color); color: var(--accent-color); font-family: var(--main-font); padding: 5px 15px; border-radius: 20px; cursor: pointer; transition: all 0.3s ease;">
        Say hello?
      </button>
    </div>

  </div>

</BaseLayout>