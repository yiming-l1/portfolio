---
import BaseLayout from "../layouts/BaseLayout.astro";

// Goofy name suggestion for the blog corner
const blogTitle = "Ramblings & Scribbles";
import notebook from "../assets/images/notebook.png";
import pen from "../assets/images/pen.png";
---

<BaseLayout title="Blog | Yiming Li">
  <style>
    .draggable {
      user-select: none;
      -webkit-user-drag: none;
      transition:
        scale 0.2s ease,
        rotate 0.2s ease;
    }
    .draggable:hover {
      scale: 1.05;
      rotate: 2deg;
    }
  </style>
  <div style="display: flex; justify-content: flex-end; margin-bottom: 40px;">
    <!-- Top-right blog line art -->
    <div
      id="art-container"
      style="position: relative; width: 250px; height: 200px;"
    >
      <img
        src={notebook.src}
        alt="Notebook"
        style="position: absolute; bottom: 0; right: 100px; width: 90%; pointer-events: none;"
      />
      <img
        id="pen"
        class="draggable"
        src={pen.src}
        alt="Pen"
        style="position: absolute; top: 50px; right: 0px; width: 130px; cursor: grab;"
      />
    </div>
  </div>

  <div style="margin-left: 20px;">
    <div style="margin-bottom: 40px;">
      <h1>{blogTitle}</h1>
      <p>Some thoughts that didn't fit anywhere else.</p>
    </div>

    <div style="display: flex; flex-direction: column; gap: 40px;">
      <!-- Blog Post Placeholder 1 -->
      <article style="border-bottom: 1px dashed #ccc; padding-bottom: 20px;">
        <h2>
          <a
            href="#"
            style="text-decoration: underline; text-decoration-color: var(--accent-color);"
            >hello world</a
          >
        </h2>
        <p
          style="font-family: var(--secondary-font); font-size: 14px; color: #666; margin-bottom: 15px;"
        >
          July 2, 2026
        </p>

        <!-- Image Placeholder -->
        <div
          style="width: 100%; max-width: 600px; height: 200px; background-color: #f5f5f5; border: 1px solid #ddd; border-radius: 8px; display: flex; align-items: center; justify-content: center; margin-bottom: 15px; color: #888;"
        >
          [image placeholder]
        </div>

        <p>
          Just setting up this little corner of the internet. Here is where I'll
          put my longer thoughts, maybe some pictures, or whatever comes to
          mind.
        </p>
      </article>

      <!-- Blog Post Placeholder 2 -->
      <article>
        <h2>
          <a
            href="#"
            style="text-decoration: underline; text-decoration-color: var(--accent-color);"
            >on building things</a
          >
        </h2>
        <p
          style="font-family: var(--secondary-font); font-size: 14px; color: #666; margin-bottom: 15px;"
        >
          June 15, 2026
        </p>

        <p>
          Building small apps is like gardening. You plant a seed, water it, and
          sometimes it just dies. But sometimes, it turns into something cool
          that people actually want to use.
        </p>
      </article>
    </div>
  </div>

  <script>
    const draggables = document.querySelectorAll(
      ".draggable",
    ) as NodeListOf<HTMLElement>;
    draggables.forEach((el) => {
      let isDragging = false;
      let currentX = 0;
      let currentY = 0;
      let startX = 0;
      let startY = 0;

      el.addEventListener("mousedown", (e: MouseEvent) => {
        isDragging = true;
        el.style.cursor = "grabbing";
        el.style.zIndex = "10";

        startX = e.clientX - currentX;
        startY = e.clientY - currentY;

        e.preventDefault();
      });

      document.addEventListener("mousemove", (e: MouseEvent) => {
        if (!isDragging) return;

        currentX = e.clientX - startX;
        currentY = e.clientY - startY;

        el.style.transform = `translate(${currentX}px, ${currentY}px)`;
      });

      document.addEventListener("mouseup", () => {
        if (isDragging) {
          isDragging = false;
          el.style.cursor = "grab";
          el.style.zIndex = "1";
        }
      });
    });
  </script>
</BaseLayout>
