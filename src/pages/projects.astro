---
import BaseLayout from "../layouts/BaseLayout.astro";
import cat from "../assets/images/cat.png";
import stick from "../assets/images/stick.png";
---

<BaseLayout title="Works | Yiming Li">
  <style>
    .draggable {
      user-select: none;
      -webkit-user-drag: none;
      transition:
        scale 0.2s ease,
        rotate 0.2s ease;
    }
    .draggable:hover {
      scale: 1.05;
      rotate: 2deg;
    }
  </style>
  <div style="display: flex; justify-content: flex-end; margin-bottom: 40px;">
    <!-- Top-right tree/cat line art -->
    <div
      id="art-container"
      style="position: relative; width: 250px; height: 250px;"
    >
      <img
        src={cat.src}
        alt="Cat"
        style="position: absolute; top: 0; right: 0; width: 110%; pointer-events: none;"
      />
      <img
        id="stick"
        class="draggable"
        src={stick.src}
        alt="Stick"
        style="position: absolute; bottom: -80px; left: 70px; width: 70px; cursor: grab;"
      />
    </div>
  </div>

  <div style="margin-left: 20px;">
    <h1 style="margin-bottom: 40px;">Works</h1>

    <div
      style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 40px;"
    >
      <!-- The Unicorn App -->
      <div class="project-card">
        <h2 style="margin-bottom: 10px;">
          <a
            href="#"
            style="text-decoration: underline; text-decoration-color: var(--accent-color);"
            >the unicorn app</a
          >
        </h2>
        <p
          style="font-family: var(--secondary-font); font-size: 14px; color: #666;"
        >
          [github link coming soon]
        </p>
        <p style="margin-top: 10px;">
          A brief description of the unicorn app project.
        </p>
      </div>

      <!-- IOT Project -->
      <div class="project-card">
        <h2 style="margin-bottom: 10px;">
          <a
            href="#"
            style="text-decoration: underline; text-decoration-color: var(--accent-color);"
            >iot project</a
          >
        </h2>
        <p
          style="font-family: var(--secondary-font); font-size: 14px; color: #666;"
        >
          [github link coming soon]
        </p>
        <p style="margin-top: 10px;">A brief description of the IOT project.</p>
      </div>

      <!-- Master Thesis -->
      <div class="project-card">
        <h2 style="margin-bottom: 10px;">
          <a
            href="#"
            style="text-decoration: underline; text-decoration-color: var(--accent-color);"
            >master thesis</a
          >
        </h2>
        <p
          style="font-family: var(--secondary-font); font-size: 14px; color: #666;"
        >
          [paper link coming soon]
        </p>
        <p style="margin-top: 10px;">
          A brief description of my master thesis research.
        </p>
      </div>

      <!-- Car Risk Assessment Model -->
      <div class="project-card">
        <h2 style="margin-bottom: 10px;">
          <a
            href="#"
            style="text-decoration: underline; text-decoration-color: var(--accent-color);"
            >car risk assessment</a
          >
        </h2>
        <p
          style="font-family: var(--secondary-font); font-size: 14px; color: #666;"
        >
          [link coming soon]
        </p>
        <p style="margin-top: 10px;">
          A brief description of the car risk assessment model.
        </p>
      </div>
    </div>
  </div>

  <script>
    const draggables = document.querySelectorAll(
      ".draggable",
    ) as NodeListOf<HTMLElement>;
    draggables.forEach((el) => {
      let isDragging = false;
      let currentX = 0;
      let currentY = 0;
      let startX = 0;
      let startY = 0;

      el.addEventListener("mousedown", (e: MouseEvent) => {
        isDragging = true;
        el.style.cursor = "grabbing";
        el.style.zIndex = "10";

        startX = e.clientX - currentX;
        startY = e.clientY - currentY;

        e.preventDefault();
      });

      document.addEventListener("mousemove", (e: MouseEvent) => {
        if (!isDragging) return;

        currentX = e.clientX - startX;
        currentY = e.clientY - startY;

        el.style.transform = `translate(${currentX}px, ${currentY}px)`;
      });

      document.addEventListener("mouseup", () => {
        if (isDragging) {
          isDragging = false;
          el.style.cursor = "grab";
          el.style.zIndex = "1";
        }
      });
    });
  </script>
</BaseLayout>
