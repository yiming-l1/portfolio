---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import emailIcon from "../assets/images/email.svg";
import githubIcon from "../assets/images/github.svg";
import linkedinIcon from "../assets/images/linkedin.svg";
---

<BaseLayout title="Contact | Yiming Li">
  <div style="display: flex; justify-content: flex-end; margin-bottom: 40px;">
    <!-- Small interactive line art element placeholder -->
    <div
      class="placeholder-art"
      style="width: 200px; height: 150px; cursor: pointer; transition: transform 0.3s ease;"
      onmouseover="this.style.transform='scale(1.05)';"
      onmouseout="this.style.transform='scale(1)';"
    >
      <p>Interactive Mailbox<br />Line Art</p>
    </div>
  </div>

  <div style="margin-left: 20px;">
    <h1>Say hi!</h1>
    <div style="margin-bottom: 40px;">
      <p>
        Email's always the best way to reach me, but you can find me in other
        places on the internet too :)
      </p>
    </div>

    <div
      style="margin-top: 40px; display: flex; flex-direction: column; gap: 20px;"
    >
      <div style="display: flex; align-items: center; gap: 15px;">
        <Image
          src={emailIcon}
          alt="email"
          style="width: 32px; height: 32px; opacity: 0.8;"
        />
        <a
          href="mailto:yimingli0120@gmail.com"
          style="text-decoration: underline; text-decoration-color: var(--accent-color);"
          >yimingli0120@gmail.com</a
        >
      </div>

      <div style="display: flex; align-items: center; gap: 15px;">
        <Image
          src={githubIcon}
          alt="github"
          style="width: 32px; height: 32px; opacity: 0.8;"
        />
        <a
          href="https://github.com/yiming-l1/"
          target="_blank"
          rel="noopener noreferrer"
          style="text-decoration: underline; text-decoration-color: var(--accent-color);"
          >github.com/yiming-l1</a
        >
      </div>

      <div style="display: flex; align-items: center; gap: 15px;">
        <Image
          src={linkedinIcon}
          alt="linkedin"
          style="width: 32px; height: 32px; opacity: 0.8;"
        />
        <a
          href="https://www.linkedin.com/in/yimingli0120/"
          target="_blank"
          rel="noopener noreferrer"
          style="text-decoration: underline; text-decoration-color: var(--accent-color);"
          >linkedin.com/in/yimingli0120</a
        >
      </div>
    </div>
  </div>
</BaseLayout>
